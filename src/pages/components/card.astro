---
import Layout from '@static/Layout.astro'

import AstroCard from '@components/Card/Card.astro'
import SvelteCard from '@components/Card/Card.svelte'
import ReactCard from '@components/Card/Card.tsx'

import { getSections } from '@helpers'

const sections = getSections({
    title: 'cards',
    components: [AstroCard, SvelteCard, ReactCard]
})
---

<Layout docs="/docs/card">
    <h1>Card</h1>

    <div class="grid md-2 lg-3">
        <AstroCard compact={true}>
            Card component using <span class="a">Astro</span>
        </AstroCard>

        <SvelteCard compact={true}>
            Card component using <span class="s">Svelte</span>
        </SvelteCard>

        <ReactCard compact={true}>
            Card component using <span class="r">React</span>
        </ReactCard>
    </div>

    {sections.map(section => (
        <h1>{section.title}</h1>
        <div class="grid md-2 lg-3">
            <section.component title="Titled card" compact={true}>
                Compact card with title
            </section.component>

            <section.component title="Spacious">
                Spacious card with title
            </section.component>

            <section.component>
                Spacious card without title
            </section.component>

            <section.component title="Secondary" secondary={true}>
                Secondary card with title
            </section.component>

            <section.component secondary={true}>
                Secondary card without title
            </section.component>

            <section.component title="Bolded" titleTag="strong">
                Card with bold title using <code>strong</code> tag.
            </section.component>

            <section.component compact={true}>
                Compact card without title
            </section.component>

            <section.component compact={true} secondary={true}>
                Compact + secondary card
            </section.component>

            <section.component flat={true} title="Flat card title">
                Flat card without <code>compact</code> or <code>secondary</code> still gets a border to prevent it from becoming invisible against the background.
            </section.component>

            <section.component flat={true} compact={true} title="Flat + Compact">
                Flat + compact card with a title
            </section.component>

            <section.component flat={true} secondary={true} title="Flat + Secondary">
                Flat + secondary card with a title
            </section.component>
        </div>
    ))}
</Layout>
